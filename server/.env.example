DATABASE_URL=postgresql://...
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-64-hex-characters

# Separate team-only credentials for /mystore/super-admin.
SUPER_ADMIN_EMAIL=admin@example.com
# Generate with: node -e "import('bcryptjs').then(({hash})=>hash('CHANGE_ME',12).then(console.log))"
SUPER_ADMIN_PASSWORD_HASH=$2b$12$replace_with_generated_bcrypt_hash

# Transactional email (doğrulama, şifre sıfırlama, kota/gecikme bildirimleri) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Çark <bildirim@yourdomain.com>

# Embed widget'ı (/api/widget/*) merkezi olarak her origin'den çağrılabilmelidir;
# bu değeri kısıtlamak yalnızca admin/super-admin panelinin çalıştığı origin'i
# etkiler, widget'ı embed eden mağaza sitelerini etkilemez.
CORS_ORIGIN=*
ADMIN_ORIGINS=https://yourdomain.com
DATA_RETENTION_DAYS=365
