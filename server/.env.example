DATABASE_URL=postgresql://...
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-64-hex-characters

# Separate team-only credentials for /mystore/super-admin.
SUPER_ADMIN_EMAIL=admin@example.com
# Generate with: node -e "import('bcryptjs').then(({hash})=>hash('CHANGE_ME',12).then(console.log))"
SUPER_ADMIN_PASSWORD_HASH=$2b$12$replace_with_generated_bcrypt_hash
